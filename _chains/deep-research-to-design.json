{
  "chain_id": "deep-research-to-design",
  "version": 1,
  "description": "Run deep-research on a topic, then feed findings into deep-design for a formal spec",
  "steps": [
    {
      "step_id": "research",
      "skill": "deep-research",
      "input_mapping": {
        "seed": "$.chain_input.topic"
      },
      "output_exports": [
        {"key": "report", "path": "research-report.md"},
        {"key": "coordinator_summary", "path": "coordinator-summary.md"}
      ],
      "on_failure": "abort"
    },
    {
      "step_id": "design",
      "skill": "deep-design",
      "input_mapping": {
        "concept": "$.chain_input.topic"
      },
      "output_exports": [
        {"key": "spec", "path": "spec.md"}
      ],
      "on_failure": "abort"
    }
  ],
  "on_chain_failure": "leave_artifacts"
}
